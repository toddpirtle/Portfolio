        "geolocator = Nominatim(user_agent=\"geo_twitter_analysis\")\n",
        "\n",
        "#Get unique locations and drop NaN values\n",
        "unique_locations = df_hurricane['location'].dropna().unique()\n",
        "\n",
        "#Dictionary to store geocoded results to avoid re-geocoding\n",
        "geocoded_cache = {}\n",
        "\n",
        "#List to store (latitude, longitude) for heatmap\n",
        "location_points = []\n",
        "\n",
        "print(f\"Attempting to geocode {len(unique_locations)} unique locations. This may take a while...\")\n",
        "\n",
        "for i, location_name in enumerate(unique_locations):\n",
        "    if location_name in geocoded_cache:\n",
        "        lat, lon = geocoded_cache[location_name]\n",
        "    else:\n",
        "        try:\n",
        "            loc = geolocator.geocode(location_name, timeout=5)\n",
        "            if loc:\n",
        "                lat, lon = loc.latitude, loc.longitude\n",
        "                geocoded_cache[location_name] = (lat, lon)\n",
        "            else:\n",
        "                lat, lon = None, None #Could not geocode\n",
        "        except Exception as e:\n",
        "            print(f\"Error geocoding '{location_name}': {e}\")\n",
        "            lat, lon = None, None\n",
        "        time.sleep(1) #Pause to respect API rate limits (1 second between requests)\n",
        "\n",
        "    if lat is not None and lon is not None:\n",
        "        location_points.append([lat, lon])\n",
        "\n",
        "    if (i + 1) % 100 == 0:\n",
        "        print(f\"Processed {i + 1}/{len(unique_locations)} locations...\")\n",
        "\n",
        "print(f\"Successfully geocoded {len(location_points)} locations out of {len(unique_locations)} unique locations.\")"
      ],
