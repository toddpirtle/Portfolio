      "source": [
        "### Text Preprocessing and Stemming\n",
        "This cell cleans the raw tweet text by removing special characters and URLs, and then applying stemming. Stemming reduces words to their root form ('earthquake' to 'earthquak') to standardize the vocabulary for modeling."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "nltk.download('stopwords')\n",
        "stemmer = SnowballStemmer(\"english\")\n",
        "stopWords = stopwords.words('english')\n",
        "\n",
        "def removeChars(sentString, sentRemovals):\n",
        "  newString = sentString\n",
        "  for char in sentRemovals:\n",
        "    newString = newString.replace(char, '')\n",
        "\n",
        "  return newString\n",
        "\n",
        "def stripURLs(sentString):\n",
        "  newString = re.sub(r\"http\\S*\", '', sentString)\n",
        "  return newString\n",
        "\n",
        "def processTweet(tweet, stop):\n",
        "    newTweet = stripURLs(tweet)\n",
        "    newTweet = removeChars(tweet, \"#@.,/\\\\?!$%^&*;:\\'\\\"\")\n",
        "    stemmedTweet = []\n",
        "\n",
        "    for word in newTweet.split():\n",
        "        if word and word not in stop:\n",
        "            newWord = stemmer.stem(word)\n",
        "            stemmedTweet.append(newWord)\n",
        "\n",
        "    return ' '.join(stemmedTweet)\n",
        "\n",
        "\n",
        "df_tweet['stemTweet'] = df_tweet['text'].apply(lambda x: processTweet(x, stopWords))"
      ],
