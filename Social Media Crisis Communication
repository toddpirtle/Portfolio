        "id": "8ee851cb",
        "outputId": "a7c1c0b0-cefd-42d5-c2b2-8b3c2034b0a3"
      },
      "source": [
        "#Count the frequency of each keyword\n",
        "keyword_counts = df_tweet['keyword'].value_counts().reset_index()\n",
        "keyword_counts.columns = ['keyword', 'count']\n",
        "\n",
        "#Get the top 50 most common keywords\n",
        "top_50_keywords = keyword_counts.head(50)\n",
        "\n",
        "#Create the bar plot (horizontal)\n",
        "plt.figure(figsize=(12, 10)) #Increased figure height to accommodate labels and text\n",
        "sns.barplot(x='count', y='keyword', data=top_50_keywords, palette='viridis', hue='keyword', legend=False)\n",
        "plt.title('Top 50 Most Common Keywords')\n",
        "\n",
        "#Remove x and y labels to save space\n",
        "plt.xlabel('')\n",
        "plt.ylabel('')\n",
        "\n",
        "#Add the count value next to each bar for easy interpretation\n",
        "for index, row in top_50_keywords.iterrows():\n",
        "    plt.text(row['count'] + 0.5, index, f\"{row['count']}\", color='black', ha=\"left\", va=\"center\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
